{
  "require": {
    "php": ">=7.3.0 <8.2.0",
    "getkirby/cms": "^3.5"
  },
  "scripts": {
    "start": [
      "Composer\\Config::disableProcessTimeout",
      "@php -S 0.0.0.0:8000 kirby/router.php"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "allow-plugins": {
      "getkirby/composer-installer": true
    }
  }
}
